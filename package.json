{
  "name": "driver-micro-services",
  "version": "1.0.0",
  "description": "Driver microservice with REST + authenticated WebSocket support for Driver Navigation PWA",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "build": "nest build",
    "build:prod": "rimraf dist && nest build",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "npm run db:migrate && npm run init:superadmin && NODE_ENV=test jest --config ./test/jest-e2e.json",
    "test:migrations": "NODE_ENV=test jest --config ./test/jest-e2e.json --runInBand test/migrations/migration-idempotency.e2e-spec.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "project:check": "ts-node scripts/project-root.ts",
    "migrate": "ts-node scripts/cli/migrate.ts",
    "db:new": "npm run migrate -- --generate",
    "db:migrate": "npm run migrate -- --run",
    "db:rollback": "npm run migrate -- --revert",
    "db:status": "npm run migrate -- --status",
    "db:simulate": "ts-node scripts/db/simulate.ts",
    "db:setup": "bash scripts/db-setup.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "db:drift": "ts-node scripts/db-drift.ts",
    "db:verify": "ts-node scripts/db-verify.ts",
    "db:health": "ts-node scripts/check-outbox-health.ts",
    "db:validate": "npm run migration:naming && npm run migration:intent && npm run migration:order && npm run migration:guard && npm run migration:rollback-check && npm run migration:transaction-check && npm run migration:size-check && npm run migration:mixed-ops-check && npm run migration:delete-safety && npm run migration:lint",
    "db:deploy": "npm run db:validate && npm run db:simulate && npm run migration:run && npm run db:verify",
    "migration:generate": "npm run project:check && ts-node scripts/migration-generate.ts",
    "migration:naming": "ts-node scripts/migration-naming-policy.ts",
    "migration:intent": "ts-node scripts/migration-intent.ts",
    "migration:order": "ts-node scripts/migration-order.ts",
    "migration:guard": "ts-node scripts/migration-guard.ts",
    "migration:rollback-check": "ts-node scripts/migration-rollback-check.ts",
    "migration:transaction-check": "ts-node scripts/migration-transaction-check.ts",
    "migration:size-check": "ts-node scripts/migration-size-check.ts",
    "migration:mixed-ops-check": "ts-node scripts/migration-mixed-ops-check.ts",
    "migration:delete-safety": "ts-node scripts/migration-delete-safety.ts",
    "migration:lint": "ts-node scripts/migration-lint.ts",
    "migration:run": "npm run project:check && npm run typeorm -- migration:run -d src/config/data-source.ts",
    "migration:revert": "npm run project:check && npm run typeorm -- migration:revert -d src/config/data-source.ts",
    "init:superadmin": "ts-node scripts/init-superadmin.ts",
    "prepare": "husky install",
    "docker:build": "docker build -t driver-micro-services .",
    "docker:run": "docker run -p 3001:3001 driver-micro-services"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.0",
    "axios": "^1.6.8",
    "axios-retry": "^4.5.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^11.1.0",
    "compression": "^1.7.4",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "nest-winston": "^1.9.7",
    "opossum": "^9.0.0",
    "p-limit": "^6.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "redis": "^4.6.13",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.37",
    "@types/opossum": "^8.1.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
