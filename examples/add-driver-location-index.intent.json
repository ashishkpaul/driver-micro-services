  "payload": {
    "table": "driver_locations",
    "index": {
      "name": "idx_driver_locations_geo",
      "columns": ["latitude", "longitude"],
      "type": "spatial"
    },
    "rollback": {
      "type": "drop-index",
      "name": "idx_driver_locations_geo"
    }
  },
  "validation": {
    "schemaVersion": "1.0.0",
    "rules": [
      "index-name-convention",
      "column-exists",
      "performance-impact"
    ]
  }
